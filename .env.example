# ═══════════════════════════════════════════════════════════════════════════════
# DOGS MIND — Backend environment variables
# Copia este archivo como .env y rellena tus claves reales.
# NUNCA subas el archivo .env a git. Ya está en .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# Obtén tu clave en: https://dash.voyageai.com/api-keys
# Modelo usado: voyage-3-large (1024 dimensiones)
VOYAGE_API_KEY=pa-...

# ── Qdrant ────────────────────────────────────────────────────────────────────
# OPCIÓN A — Local (Docker):
#   docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OPCIÓN B — Qdrant Cloud:
#   Crea un cluster en https://cloud.qdrant.io
#   Pega la URL del cluster y la API key que te dan
# QDRANT_URL=https://xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# ── Colección Qdrant ──────────────────────────────────────────────────────────
# Nombre de la colección donde se indexan los PDFs.
# Se crea automáticamente al arrancar el servidor si no existe.
QDRANT_COLLECTION=dogs_mind_knowledge

# ── Modelos de IA ─────────────────────────────────────────────────────────────
# IA Clínica: Claude Sonnet 4.6 con RAG + prompt caching
CLINICAL_MODEL=claude-sonnet-4-6
# Avatar conversacional: Claude Haiku 4.5 (sin RAG)
AVATAR_MODEL=claude-haiku-4-5
# Embeddings: Voyage AI voyage-3-large
EMBEDDING_MODEL=voyage-3-large

# ── Parámetros RAG ────────────────────────────────────────────────────────────
# Número de chunks recuperados por consulta
RAG_TOP_K=6
# Tamaño del chunk en palabras
CHUNK_SIZE=600
# Solapamiento entre chunks consecutivos (palabras)
CHUNK_OVERLAP=80

# ── Aplicación ────────────────────────────────────────────────────────────────
# "development" → CORS abierto a *
# "production"  → CORS restringido (configura origins en main.py)
APP_ENV=development
